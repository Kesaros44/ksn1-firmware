/*
 * ksn_1.keymap — 좌우 통합 키맵
 *
 * 레이어:
 *   0 DEF  - 기본
 *   1 FUNC - 기능/BT (슬레이브 ROW6 COL4 = mo FUNC)
 *   2 LEDC - LED 제어 (마스터 Caps 홀드 200ms)
 *
 * 엔코더 (슬레이브):
 *   DEF  : 회전=볼륨 up/down  / 클릭=재생·정지
 *   FUNC : 회전=트랙 next/prev / 클릭=뮤트
 *   LEDC : 회전=LED 밝기      / 클릭=LED ON·OFF
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/rgb.h>
#include <dt-bindings/zmk/outputs.h>

#define DEF  0
#define FUNC 1
#define LEDC 2

/ {
    behaviors {
        /* Caps: 짧게=CapsLock / 길게=LEDC 레이어 */
        caps_ledc: caps_ledc {
            compatible      = "zmk,behavior-hold-tap";
            label           = "CAPS_LEDC";
            #binding-cells  = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms    = <0>;
            flavor          = "tap-preferred";
            bindings        = <&mo>, <&kp>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        /* ═══════════════════════════════════════════════════
           레이어 0 : DEFAULT
           엔코더: 회전=볼륨 / 클릭=재생정지
        ══════════════════════════════════════════════════ */
        default_layer {
            label = "DEFAULT";
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
            bindings = <
/*          ┌─── 마스터(왼쪽) 11키 ──────────────────────────────────────┐  ┌─── 슬레이브(오른쪽) 11키 ──────────────────────────────────────┐ */
/* ROW1 */ &none       &none       &kp BSPC    &kp DEL     &kp ESC     &none       &kp F1      &kp F2      &kp F3      &kp F4      &kp F5        &none       &kp F6      &kp F7      &kp F8      &kp F9      &kp F10     &kp F11     &kp F12     &kp PSCRN   &kp SLCK    &kp PAUSE_BREAK
/* ROW2 */ &kp KP_NUM  &kp KP_DIV  &kp KP_MUL  &kp KP_MINUS &kp GRAVE  &kp N1      &kp N2      &kp N3      &kp N4      &kp N5      &kp N6        &none       &kp N7      &kp N8      &kp N9      &kp N0      &kp MINUS   &kp EQUAL   &kp BSPC    &kp INS     &kp HOME    &kp PG_UP
/* ROW3 */ &kp KP_N7   &kp KP_N8   &kp KP_N9   &kp KP_PLUS  &kp TAB    &kp Q       &kp W       &kp E       &kp R       &kp T       &none         &kp Y       &kp U       &kp I       &kp O       &kp P       &kp LBKT    &kp RBKT    &kp BSLH    &kp DEL     &kp END     &kp PG_DN
/* ROW4 */ &kp KP_N4   &kp KP_N5   &kp KP_N6   &none        &caps_ledc LEDC CAPS   &kp A       &kp S       &kp D       &kp F       &kp G       &none         &kp H       &kp J       &kp K       &kp L       &kp SEMI    &kp SQT     &none       &kp RET     &none       &none       &none
/* ROW5 */ &kp KP_N1   &kp KP_N2   &kp KP_N3   &kp KP_ENTER &kp LSHFT  &none       &kp Z       &kp X       &kp C       &kp V       &kp B         &kp B       &kp N       &kp M       &kp COMMA   &kp DOT     &kp FSLH    &none       &kp RSHFT   &none       &kp UP      &none
/* ROW6 */ &kp KP_N0   &none       &kp KP_DOT  &none        &kp LCTRL  &kp LGUI    &kp LALT    &none       &kp SPACE   &none       &none         &none       &kp SPACE   &none       &mo FUNC    &kp RALT    &kp RGUI    &kp K_APP   &kp RCTRL   &kp LEFT    &kp DOWN    &kp RIGHT
            >;
        };

        /* ═══════════════════════════════════════════════════
           레이어 1 : FUNC
           엔코더: 회전=트랙 next/prev / 클릭=뮤트
        ══════════════════════════════════════════════════ */
        func_layer {
            label = "FUNC";
            sensor-bindings = <&inc_dec_kp C_NEXT C_PREV>;
            bindings = <
/* ROW1 */ &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans        &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &bt BT_CLR
/* ROW2  BT 프로파일 선택 / 출력 전환 */
           &trans      &trans      &trans      &trans      &trans      &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &bt BT_SEL 4 &out OUT_TOG  &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans
/* ROW3 */ &trans      &trans      &trans      &trans      &trans      &kp F6      &kp F7      &kp F8      &kp F9      &kp F10     &trans        &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans
/* ROW4 */ &trans      &trans      &trans      &trans      &trans      &kp F11     &kp F12     &trans      &trans      &trans      &trans        &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans
/* ROW5 */ &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans        &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans
/* ROW6 */ &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans        &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans      &trans
            >;
        };

        /* ═══════════════════════════════════════════════════
           레이어 2 : LED_CTRL (Caps 홀드 진입)
           엔코더: 회전=밝기 up/down / 클릭=LED ON·OFF
        ══════════════════════════════════════════════════ */
        led_ctrl_layer {
            label = "LED_CTRL";
            sensor-bindings = <&inc_dec_kp RGB_BRI RGB_BRD>;
            bindings = <
/* ROW1 */ &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans            &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans
/* ROW2 */ &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans            &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans
/* ROW3  LED ON/OFF, 효과 */
           &trans          &trans          &trans          &trans          &trans          &rgb_ug RGB_TOG &rgb_ug RGB_EFF &rgb_ug RGB_EFR &trans          &trans          &trans            &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans
/* ROW4  색조/채도 */
           &trans          &trans          &trans          &trans          &trans          &rgb_ug RGB_HUI &rgb_ug RGB_HUD &rgb_ug RGB_SAI &rgb_ug RGB_SAD &trans          &trans            &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans
/* ROW5  밝기 */
           &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &rgb_ug RGB_BRI &rgb_ug RGB_BRD &trans            &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans
/* ROW6 */ &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans            &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans          &trans
            >;
        };
    };
};
