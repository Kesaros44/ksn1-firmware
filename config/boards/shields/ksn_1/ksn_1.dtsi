/*
 * ksn_1.dtsi — 좌우 공통 하드웨어 정의
 *
 * ┌─────────────────────────────────────────┐
 * │  nice!nano v2.0 공식 핀맵 기준          │
 * │  (Image3 핀맵 직접 확인)                │
 * ├──────┬──────┬────────────────────────── │
 * │ 회로 │ 보드 │ GPIO                      │
 * ├──────┼──────┼────────────────────────── │
 * │ row1 │ D6   │ P1.00                     │
 * │ row2 │ D5   │ P0.24                     │
 * │ row3 │ D4   │ P0.22                     │
 * │ row4 │ D2   │ P0.17                     │
 * │ row5 │ D0   │ P0.08                     │
 * │ row6 │ D1   │ P0.06                     │
 * ├──────┼──────┼────────────────────────── │
 * │ col1 │ D7   │ P0.11                     │
 * │ col2 │ D8   │ P1.04                     │
 * │ col3 │ D9   │ P1.06                     │
 * │ col4 │ P1.07│ P1.07                     │
 * │ col5 │ P1.02│ P1.02                     │
 * │ col6 │ P1.01│ P1.01                     │
 * │ col7 │ D18  │ P1.15                     │
 * │ col8 │ D15  │ P1.13                     │
 * │ col9 │ D14  │ P1.11                     │
 * │ col10│ D16  │ P0.10                     │
 * │ col11│ D10  │ P0.09                     │
 * └──────┴──────┴────────────────────────── │
 *
 * 다이오드 방향: col2row
 */

/ {
    chosen {
        zmk,kscan            = &kscan0;
        zmk,matrix_transform = &default_transform;
        zmk,battery          = &vbatt;
    };

    /* ───────────────────────────────────────
       매트릭스 변환 (6행 × 22열 = 좌11 + 우11)
    ─────────────────────────────────────── */
    default_transform: matrix_transform {
        compatible = "zmk,matrix-transform";
        columns = <22>;
        rows    = <6>;
        map = <
RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)  RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10)    RC(0,11) RC(0,12) RC(0,13) RC(0,14) RC(0,15) RC(0,16) RC(0,17) RC(0,18) RC(0,19) RC(0,20) RC(0,21)
RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)  RC(1,6)  RC(1,7)  RC(1,8)  RC(1,9)  RC(1,10)    RC(1,11) RC(1,12) RC(1,13) RC(1,14) RC(1,15) RC(1,16) RC(1,17) RC(1,18) RC(1,19) RC(1,20) RC(1,21)
RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)  RC(2,6)  RC(2,7)  RC(2,8)  RC(2,9)  RC(2,10)    RC(2,11) RC(2,12) RC(2,13) RC(2,14) RC(2,15) RC(2,16) RC(2,17) RC(2,18) RC(2,19) RC(2,20) RC(2,21)
RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)  RC(3,5)  RC(3,6)  RC(3,7)  RC(3,8)  RC(3,9)  RC(3,10)    RC(3,11) RC(3,12) RC(3,13) RC(3,14) RC(3,15) RC(3,16) RC(3,17) RC(3,18) RC(3,19) RC(3,20) RC(3,21)
RC(4,0)  RC(4,1)  RC(4,2)  RC(4,3)  RC(4,4)  RC(4,5)  RC(4,6)  RC(4,7)  RC(4,8)  RC(4,9)  RC(4,10)    RC(4,11) RC(4,12) RC(4,13) RC(4,14) RC(4,15) RC(4,16) RC(4,17) RC(4,18) RC(4,19) RC(4,20) RC(4,21)
RC(5,0)  RC(5,1)  RC(5,2)  RC(5,3)  RC(5,4)  RC(5,5)  RC(5,6)  RC(5,7)  RC(5,8)  RC(5,9)  RC(5,10)    RC(5,11) RC(5,12) RC(5,13) RC(5,14) RC(5,15) RC(5,16) RC(5,17) RC(5,18) RC(5,19) RC(5,20) RC(5,21)
        >;
    };

    /* ───────────────────────────────────────
       키 스캔 (col2row 다이오드 방향)
       col2row: row=출력(Active High)
                col=입력(Active High + Pull Down)
    ─────────────────────────────────────── */
    kscan0: kscan {
        compatible      = "zmk,kscan-gpio-matrix";
        label           = "KSCAN";
        diode-direction = "col2row";

        row-gpios
            = <&gpio1 0  GPIO_ACTIVE_HIGH>   /* D6  P1.00 row1 */
            , <&gpio0 24 GPIO_ACTIVE_HIGH>   /* D5  P0.24 row2 */
            , <&gpio0 22 GPIO_ACTIVE_HIGH>   /* D4  P0.22 row3 */
            , <&gpio0 17 GPIO_ACTIVE_HIGH>   /* D2  P0.17 row4 */
            , <&gpio0 8  GPIO_ACTIVE_HIGH>   /* D0  P0.08 row5 */
            , <&gpio0 6  GPIO_ACTIVE_HIGH>   /* D1  P0.06 row6 */
            ;

        col-gpios
            = <&gpio0 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* D7   P0.11 col1  */
            , <&gpio1 4  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* D8   P1.04 col2  */
            , <&gpio1 6  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* D9   P1.06 col3  */
            , <&gpio1 7  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* P1.07      col4  */
            , <&gpio1 2  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* P1.02      col5  */
            , <&gpio1 1  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* P1.01      col6  */
            , <&gpio1 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* D18  P1.15 col7  */
            , <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* D15  P1.13 col8  */
            , <&gpio1 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* D14  P1.11 col9  */
            , <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* D16  P0.10 col10 */
            , <&gpio0 9  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* D10  P0.09 col11 */
            ;
    };

    /* ───────────────────────────────────────
       배터리 전압 분배기
       스위치출력 → 820kΩ → P0.31(AIN7) → 2MΩ → GND
    ─────────────────────────────────────── */
    vbatt: vbatt {
        compatible  = "zmk,battery-voltage-divider";
        label       = "VBATT";
        io-channels = <&adc 7>;      /* P0.31 = AIN7 */
        output-ohms = <2000000>;     /* 2MΩ          */
        full-ohms   = <2820000>;     /* 820kΩ + 2MΩ  */
    };
};

&adc { status = "okay"; };
