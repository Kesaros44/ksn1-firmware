/*
 * ksn_1_left.overlay — 하드웨어 스왑 반영 (Backlight = D1)
 */

#include "ksn_1.dtsi"

&pinctrl {
    pwm0_default: pwm0_default {
        group1 {
            /* PWM 출력을 P0.06 (D1) 으로 변경 */
            psels = <NRF_PSEL(PWM_OUT0, 0, 6)>; 
            low-power-enable;
        };
    };
};

&pwm0 {
    status = "okay";
    pinctrl-0 = <&pwm0_default>;
    pinctrl-names = "default";
};

/ {
    /* 백라이트가 D1 (P0.06) 을 쓰도록 설정 */
    backlight {
        compatible = "pwm-backlight";
        pwms = <&pwm0 0 10000 PWM_POLARITY_NORMAL>;
    };
};
